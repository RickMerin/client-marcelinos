
VITE_ENV=development
VITE_SITE_URL=https://marcelinos-resort-hotel.com
VITE_API_URL_DEV=http://127.0.0.1:8000/api
VITE_API_URL_PROD=https://api.example.com/api
VITE_API_KEY=your_api_key_here

# Cloudflare Turnstile (site key for the widget; server uses TURNSTILE_SECRET_KEY on the API)
# VITE_TURNSTILE_SITE_KEY=

# Send browser error reports to POST /api/client-errors (requires SLACK_ERROR_ALERTS_ENABLED on API). Off in dev unless true.
# VITE_ERROR_REPORTING=true

# Facebook Messenger page ID for billing-statement “Open Messenger” (preferred).
# VITE_MESSENGER_PAGE_ID=61557457680496
# Optional full URL override (kept for backward compatibility):
# VITE_MESSENGER_URL=https://m.me/your-page-id

# Production host(s) where search engines may index (comma-separated). All other domains get noindex.
# Example: VITE_PRODUCTION_HOST=marcelinos.com,marcelinos.vercel.app
# VITE_PRODUCTION_HOST=marcelinos.com

# Realtime (Pusher / Pusher-compatible websockets). Optional; defaults from API URL + local-key.
# Local: VITE_WS_PORT=8080, VITE_WS_SCHEME=http
# Production (behind proxy): VITE_WS_PORT=443, VITE_WS_SCHEME=https
# VITE_WS_HOST=localhost
# VITE_WS_PORT=8080
# VITE_WS_KEY=local-key
# VITE_WS_CLUSTER=ap1
# VITE_WS_SCHEME=http
