
VITE_ENV=development
VITE_API_URL_DEV=http://127.0.0.1:8000/api
VITE_API_URL_PROD=https://api.example.com/api
VITE_API_KEY=your_api_key_here

# Production host(s) where search engines may index (comma-separated). All other domains get noindex.
# Example: VITE_PRODUCTION_HOST=marcelinos.com,marcelinos.vercel.app
# VITE_PRODUCTION_HOST=marcelinos.com

# Realtime (Laravel Reverb). Optional; defaults derived from API URL and local-key.
# VITE_WS_HOST=localhost
# VITE_WS_PORT=8080
# VITE_WS_KEY=local-key
# VITE_WS_SCHEME=http
